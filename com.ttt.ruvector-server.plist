<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ttt.ruvector-server</string>
    <key>ProgramArguments</key>
    <array>
        <string>__RUVECTOR_SERVER__</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>RUVECTOR_HOST</key>
        <string>127.0.0.1</string>
        <key>RUVECTOR_PORT</key>
        <string>6333</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/ruvector-server.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/ruvector-server.err.log</string>
</dict>
</plist>
